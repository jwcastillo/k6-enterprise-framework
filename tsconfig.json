{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@core/*": ["./src/core/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@node/*": ["./src/node/*"],
      "@observability/*": ["./src/observability/*"],
      "@patterns/*": ["./src/patterns/*"],
      "@reporting/*": ["./src/reporting/*"],
      "@types-k6/*": ["./src/types/*"],
    },
    "types": ["k6", "node"],
  },
  "include": ["src/**/*", "clients/**/*"],
  "exclude": ["node_modules", "dist", "poc", "archive/**"],
}
