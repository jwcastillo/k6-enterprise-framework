# k6 Enterprise Framework — Infrastructure Environment Variables
#
# T-146 / T-150: All configurable variables for the Docker Compose stack.
#
# Usage:
#   cp infrastructure/.env.example infrastructure/.env
#   # Edit .env with your values (it is gitignored)
#   docker compose --env-file infrastructure/.env up -d
#
# SECURITY NOTICE:
#   Never commit real credentials to version control.
#   For production, prefer shell environment injection or Docker secrets.
#   See docker-compose.secrets.yml for Docker secrets-based configuration.

# ── Image versions ────────────────────────────────────────────────────────────
GRAFANA_VERSION=12.4.0
PROMETHEUS_VERSION=v3.10.0
LOKI_VERSION=3.6.7
TEMPO_VERSION=2.10.1
PYROSCOPE_VERSION=1.18.1
REDIS_VERSION=7.4-alpine
K6_VERSION=1.6.1
OTEL_COLLECTOR_VERSION=0.152.0

# ── Host ports (only Grafana and k6 API exposed by default) ──────────────────
GRAFANA_HOST_PORT=3000
K6_API_HOST_PORT=6565

# ── Grafana credentials ───────────────────────────────────────────────────────
# Development: anonymous viewer access is enabled by default (GF_AUTH_ANONYMOUS_ENABLED=true)
# Production: set GF_AUTH_ANONYMOUS_ENABLED=false and provide strong credentials below.
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<change-me-in-production>
# GF_SECURITY_SECRET_KEY — required for production session signing (run: openssl rand -base64 32)
# GF_SECURITY_SECRET_KEY=<change-me-in-production>

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave empty to disable Redis authentication (development only)
# In production, set a strong password: openssl rand -base64 20
REDIS_PASSWORD=
REDIS_MAXMEMORY=512mb

# ── Data retention ────────────────────────────────────────────────────────────
# Number of days to retain metrics/logs/traces (used by Prometheus, Loki, Tempo)
RETENTION_DAYS=30

# ── Notifications (NotificationService + bin/notify.js) ──────────────────────
# NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/T000/B000/XXXX
# NOTIFY_EMAIL_TO=oncall@example.com
# NOTIFY_EMAIL_ENDPOINT=https://email-relay.example.com/send
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/k6-results
