{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "k6 Enterprise Framework — Browser Web Vitals. Shows Core Web Vitals (LCP, FCP, INP, CLS, TTFB) from k6 browser tests with Google's Good/Needs Improvement/Poor thresholds.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Load Test Overview",
      "tooltip": "Switch to HTTP metrics dashboard",
      "type": "link",
      "url": "/d/k6-load-test-overview"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Core Web Vitals — Gauges (p90)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null },
              { "color": "#f59e0b", "value": 2.5 },
              { "color": "#ef4444", "value": 4.0 }
            ]
          },
          "unit": "s",
          "min": 0,
          "max": 6
        }
      },
      "gridPos": { "h": 7, "w": 5, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      },
      "title": "LCP (Largest Contentful Paint)",
      "description": "Time until the largest visible content element is rendered.\n\nGoogle thresholds: Good < 2.5s | Needs Improvement < 4s | Poor >= 4s",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(k6_browser_web_vital_lcp_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"})",
          "legendFormat": "LCP p90",
          "refId": "A"
        }
      ],
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null },
              { "color": "#f59e0b", "value": 1.8 },
              { "color": "#ef4444", "value": 3.0 }
            ]
          },
          "unit": "s",
          "min": 0,
          "max": 5
        }
      },
      "gridPos": { "h": 7, "w": 5, "x": 5, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      },
      "title": "FCP (First Contentful Paint)",
      "description": "Time until the first content element is rendered.\n\nGoogle thresholds: Good < 1.8s | Needs Improvement < 3s | Poor >= 3s",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(k6_browser_web_vital_fcp_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"})",
          "legendFormat": "FCP p90",
          "refId": "A"
        }
      ],
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null },
              { "color": "#f59e0b", "value": 0.2 },
              { "color": "#ef4444", "value": 0.5 }
            ]
          },
          "unit": "s",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 7, "w": 4, "x": 10, "y": 1 },
      "id": 5,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      },
      "title": "INP (Interaction to Next Paint)",
      "description": "Responsiveness to user interactions (clicks, taps, key presses).\n\nGoogle thresholds: Good < 200ms | Needs Improvement < 500ms | Poor >= 500ms",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(k6_browser_web_vital_inp_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"})",
          "legendFormat": "INP p90",
          "refId": "A"
        }
      ],
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null },
              { "color": "#f59e0b", "value": 0.1 },
              { "color": "#ef4444", "value": 0.25 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 0.5,
          "decimals": 4
        }
      },
      "gridPos": { "h": 7, "w": 5, "x": 14, "y": 1 },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      },
      "title": "CLS (Cumulative Layout Shift)",
      "description": "Visual stability score. Lower is better.\n\nGoogle thresholds: Good < 0.1 | Needs Improvement < 0.25 | Poor >= 0.25",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(k6_browser_web_vital_cls_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"})",
          "legendFormat": "CLS p90",
          "refId": "A"
        }
      ],
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null },
              { "color": "#f59e0b", "value": 0.8 },
              { "color": "#ef4444", "value": 1.8 }
            ]
          },
          "unit": "s",
          "min": 0,
          "max": 3
        }
      },
      "gridPos": { "h": 7, "w": 5, "x": 19, "y": 1 },
      "id": 4,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      },
      "title": "TTFB (Time to First Byte)",
      "description": "Server response time for the initial document request.\n\nGoogle thresholds: Good < 800ms | Needs Improvement < 1800ms | Poor >= 1800ms",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(k6_browser_web_vital_ttfb_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"})",
          "legendFormat": "TTFB p90",
          "refId": "A"
        }
      ],
      "type": "gauge"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "title": "Web Vitals Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "seconds",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "always",
            "spanNulls": true,
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(245,158,11,0.1)", "value": 2.5 },
              { "color": "rgba(239,68,68,0.1)", "value": 4.0 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 10, "w": 6, "x": 0, "y": 9 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "LCP & FCP Over Time",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(k6_browser_web_vital_lcp_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"})",
          "legendFormat": "LCP p90",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(k6_browser_web_vital_fcp_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"})",
          "legendFormat": "FCP p90",
          "refId": "C"
        }
