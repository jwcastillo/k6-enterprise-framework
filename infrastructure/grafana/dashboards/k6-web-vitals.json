    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 102,
      "title": "Web Vitals by Page URL",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#22c55e", "value": null },
              { "color": "#f59e0b", "value": 2.5 },
              { "color": "#ef4444", "value": 4.0 }
            ]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "INP p90" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#22c55e", "value": null },
                    { "color": "#f59e0b", "value": 0.2 },
                    { "color": "#ef4444", "value": 0.5 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CLS p90" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 4 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#22c55e", "value": null },
                    { "color": "#f59e0b", "value": 0.1 },
                    { "color": "#ef4444", "value": 0.25 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "TTFB p90" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#22c55e", "value": null },
                    { "color": "#f59e0b", "value": 0.8 },
                    { "color": "#ef4444", "value": 1.8 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "FCP p90" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#22c55e", "value": null },
                    { "color": "#f59e0b", "value": 1.8 },
                    { "color": "#ef4444", "value": 3.0 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "URL" },
            "properties": [
              { "id": "custom.width", "value": 400 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "id": 20,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "LCP p90" }],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "title": "Web Vitals Breakdown by URL",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (url)(last_over_time(k6_browser_web_vital_lcp_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (url)(last_over_time(k6_browser_web_vital_fcp_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (url)(last_over_time(k6_browser_web_vital_inp_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (url)(last_over_time(k6_browser_web_vital_cls_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (url)(last_over_time(k6_browser_web_vital_ttfb_p90{test_name=~\"$test_name\", client=~\"$client\", environment=~\"$environment\", test_timestamp=~\"$test_timestamp\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "D"
        }
      ],
