# k6 Enterprise Framework — Environment Variables Template
#
# T-139: SECURITY NOTICE
# This file is a TEMPLATE only. Never add real credentials, tokens, or secrets here.
# 1. Copy this file: cp .env.example .env
# 2. Fill in values in .env (already in .gitignore)
# 3. For CI/CD: inject secrets via your pipeline's secret store (GitHub Secrets, GitLab CI Variables)
#
# Recommended secret retrieval:
#   export APP_API_KEY="$(vault kv get -field=api_key secret/myapp)"
#   export APP_API_KEY="$(aws secretsmanager get-secret-value --secret-id myapp/api_key --query SecretString --output text)"

# ── Execution ───────────────────────────────────────────────────────────────
# Default load profile (smoke|quick|load|rampup|capacity|stress|spike|breakpoint|soak)
K6_PROFILE=smoke

# Target environment (default|staging|production)
K6_ENV=default

# Client/product name (matches clients/<CLIENT_NAME>/)
K6_CLIENT=_reference

# ── Secrets backends ────────────────────────────────────────────────────────
# Comma-separated list of enabled backends (env|vault|aws-sm|azure-kv)
K6_SECRETS_BACKENDS=env

# HashiCorp Vault
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=<your-vault-token>
VAULT_NAMESPACE=<your-vault-namespace>

# AWS Secrets Manager
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>

# Azure Key Vault
AZURE_KEYVAULT_URL=https://myvault.vault.azure.net
AZURE_CLIENT_ID=<your-azure-client-id>
AZURE_CLIENT_SECRET=<your-azure-client-secret>
AZURE_TENANT_ID=<your-azure-tenant-id>

# ── Observability ────────────────────────────────────────────────────────────
# Enable Tempo distributed tracing
K6_TEMPO_ENABLED=false
TEMPO_ENDPOINT=http://localhost:3200

# OBS2-03 (Phase 09): Head-based sampling ratio for distributed tracing.
# 1.0 = sample every iteration (default); 0.1 = sample ~10% of iterations
# (deterministic per-iteration draw — replay-friendly). Out-of-range values
# are clamped to [0.0, 1.0]. Unsampled iterations still emit a traceparent
# header with flags=00 so downstream services see the propagated context,
# but the OTel collector / Tempo drops the unsampled trace data.
K6_TEMPO_SAMPLING_RATIO=1.0

# Enable Pyroscope continuous profiling
K6_PYROSCOPE_ENABLED=false
PYROSCOPE_ENDPOINT=http://localhost:4040

# OBS2-02 (Phase 09): Node-host continuous profiling. When true, bin/run-test.sh
# starts a Node sidecar that pushes profiles to PYROSCOPE_ENDPOINT for the duration
# of the k6 run. Rejected for profile=capacity|stress|breakpoint|soak (the 2-5%
# overhead would invalidate capacity measurements).
K6_PYROSCOPE_CONTINUOUS=false

# OBS2-01 (Phase 08): OTel Collector routing — preferred over Tempo-direct
# When K6_OTEL_ENABLED=true, OTLP traces+metrics flow through the collector
# (http://localhost:4317 by default) which fans out to Tempo + Prometheus
# remote-write. Resource attributes run_id, client, scenario, profile are
# auto-populated by bin/run-test.sh from RUN_ID/CLIENT/SCENARIO/PROFILE.
K6_OTEL_ENABLED=false
K6_OTEL_GRPC_EXPORTER_ENDPOINT=http://localhost:4317
# Optional: extra resource attributes appended to the canonical four.
# Format: comma-separated key=value pairs. Example:
#   K6_OTEL_RESOURCE_ATTRIBUTES=deployment.environment=staging,git.commit=abc123
K6_OTEL_RESOURCE_ATTRIBUTES=

# ── Notifications (NotificationService + bin/notify.js) ──────────────────────
# NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/T000/B000/XXXX
# NOTIFY_EMAIL_TO=oncall@example.com
# NOTIFY_EMAIL_ENDPOINT=https://email-relay.example.com/send
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/k6-results

# ── Logging ──────────────────────────────────────────────────────────────────
# Enable structured JSON logging (compatible with ELK/Splunk/Datadog)
K6_STRUCTURED_LOGS=false

# Enable verbose debug logging
K6_DEBUG=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>
REDIS_DB=0

# ── Reporting ────────────────────────────────────────────────────────────────
# Output directory for generated reports
K6_REPORTS_DIR=./reports

# Baseline file for auto-comparison (path to previous JSON summary)
K6_BASELINE_FILE=

# ── Application secrets (example — use real secret names per client) ─────────
# These are injected at runtime and never appear in scripts.
# Replace <placeholder> values with actual secrets in your .env file (never here).
APP_API_KEY=<your-api-key>
APP_USERNAME=<your-username>
APP_PASSWORD=<your-password>

# === AI Module ===
# API key for the LLM provider. LLM_API_KEY is the canonical name;
# ANTHROPIC_API_KEY is accepted as a legacy alias.
ANTHROPIC_API_KEY=
LLM_API_KEY=

# ChromaDB connection for RAG (optional). Leave unset to disable RAG.
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Set to "true" to fail-hard when ChromaDB is requested but unreachable.
# Default: warn and continue without RAG (degraded mode).
K6_AI_REQUIRE_RAG=false

# Set to "true" to let SelfHealingEngine apply fixes without interactive prompt.
# CI-friendly. Default: prompt or no-op depending on TTY.
K6_AI_AUTO_APPLY=false

# Pricing overrides (USD per 1K tokens). Default values live in
# src/ai/core/pricing.json. Set these to simulate cost changes without
# editing the file.
LLM_INPUT_USD_PER_1K=
LLM_OUTPUT_USD_PER_1K=
