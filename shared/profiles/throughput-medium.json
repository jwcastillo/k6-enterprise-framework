{
  "name": "throughput-medium",
  "description": "Medium constant throughput (50 req/s) — arrival-rate open model",
  "executor": "constant-arrival-rate",
  "rate": 50,
  "timeUnit": "1s",
  "duration": "5m",
  "preAllocatedVUs": 60,
  "maxVUs": 150,
  "thresholds": {
    "http_req_duration": ["p(95)<1500", "p(99)<3000"],
    "http_req_failed": ["rate<0.05"],
    "checks": ["rate>=0.95"]
  },
  "maxDuration": "6m"
}
