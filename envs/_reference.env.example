# Reference Client — Secrets Template
#
# SECURITY: This file is a TEMPLATE only. Never add real credentials here.
#   1. Copy: cp envs/_reference.env.example envs/_reference.env
#   2. Fill values in envs/_reference.env (gitignored)
#   3. Run: k6 run --env-file=envs/_reference.env <scenario>

# ── Execution ─────────────────────────────────────────────────────────────────

K6_PROFILE=smoke
K6_ENV=default
K6_CLIENT=_reference

# ── Secrets backends ──────────────────────────────────────────────────────────

K6_SECRETS_BACKENDS=env

# ── Application secrets ──────────────────────────────────────────────────────

APP_API_KEY=<your-api-key>
APP_USERNAME=<your-username>
APP_PASSWORD=<your-password>

# ── AI Features (optional) ──────────────────────────────────────────────────
# Used by AI agents (planner, builder, analyst, reporter, self-healing).
# Supports any Anthropic-compatible API key.
# Resolution order: LLM_API_KEY → ANTHROPIC_API_KEY → constructor param

LLM_API_KEY=<your-llm-api-key>
