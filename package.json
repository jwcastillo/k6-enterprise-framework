{
  "name": "k6-enterprise-framework",
  "version": "0.2.0",
  "description": "k6 Enterprise Load Testing Framework — two-layer architecture with reusable helpers, patterns, and multi-client isolation",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:watch": "webpack --config webpack.config.js --watch",
    "lint": "eslint 'src/**/*.ts' 'clients/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'clients/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'clients/**/*.ts' '*.json'",
    "format:check": "prettier --check 'src/**/*.ts' 'clients/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm typecheck && pnpm lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:reference": "k6 run dist/reference-smoke.js",
    "prepare": "husky",
    "docs:sync": "node docs-site/scripts/sync-docs.mjs",
    "docs:start": "pnpm docs:sync && cd docs-site && pnpm start",
    "docs:start:es": "pnpm docs:sync && cd docs-site && pnpm start -- --locale es",
    "docs:build": "pnpm docs:sync && cd docs-site && pnpm build",
    "docs:serve": "cd docs-site && pnpm serve"
  },
  "keywords": [
    "k6",
    "load-testing",
    "performance",
    "performance-testing",
    "stress-testing",
    "typescript",
    "observability",
    "enterprise"
  ],
  "author": "José Castillo <jwcastillo@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jwcastillo/k6-enterprise-framework.git"
  },
  "bugs": {
    "url": "https://github.com/jwcastillo/k6-enterprise-framework/issues"
  },
  "homepage": "https://github.com/jwcastillo/k6-enterprise-framework#readme",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/k6": "^2.0.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commitizen": "^4.3.2",
    "copy-webpack-plugin": "^14.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "inquirer": "^14.0.2",
    "js-yaml": "^4.2.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0",
    "vitest": "^4.1.8",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "ioredis": "^5.11.1"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@pyroscope/nodejs": "^0.4.11",
    "playwright": "^1.58.2"
  }
}
